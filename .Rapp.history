simulate_contrib_effect_correct <- function(n_years, monthly_contrib, annual_raise_pct) {#
  contrib <- numeric(n_years)#
  for (y in 1:n_years) {#
    contrib[y] <- monthly_contrib * 12 * ((1 + annual_raise_pct)^(y - 1))#
  }#
  cumsum(contrib)#
}#
