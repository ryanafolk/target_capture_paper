initial_balance <- 193000#
#
# Compute cumulative contributions and portfolio value medians#
simA_cum <- simA_long %>%#
  group_by(Year) %>%#
  summarize(MedianValue = quantile(Value, 0.5, na.rm = TRUE)) %>%#
  mutate(#
    # assume contributions are monthly * 12, growing with salary#
    annual_contrib = monthly_contrib * 12 * ((1 + annual_raise_pct)^(Year - 1)),#
    cum_contrib = cumsum(annual_contrib),#
    # adjust first year to include initial contributions#
    cum_contrib = ifelse(Year == 1, first_year_contrib, cum_contrib + first_year_contrib),#
    contrib_effect = cum_contrib / MedianValue#
  )#
#
ggplot(simA_cum, aes(x = Year, y = contrib_effect)) +#
  geom_line(color = "#2ca02c", linewidth = 1.2) +#
  scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +#
