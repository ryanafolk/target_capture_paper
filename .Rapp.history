#
ci_spend <- sim_spend_all %>%#
	group_by(Portfolio, Year) %>%#
	summarize(MedianValue = quantile(Value, 0.5, na.rm = TRUE),#
	Lower = quantile(Value, 0.05, na.rm = TRUE),#
