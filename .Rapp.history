# Wide format#
simA_wide <- simA_long %>%#
  filter(Portfolio == "A") %>%#
  pivot_wider(names_from = Year, values_from = Value) %>%#
  select(-Portfolio)#
#
initial_value <- simA_long %>% filter(Portfolio == "A", Year == 1) %>% pull(Value) %>% median()#
#
# Function to get Nth doubling year#
nth_doubling <- function(x, n, init) {#
  years <- which(x >= 2^n * init)#
  if(length(years) == 0) return(NA)#
  return(years[1])#
}#
#
doubling_times_df <- data.frame(#
  First  = apply(simA_wide[,-1], 1, nth_doubling, n=1, init=initial_value),#
  Second = apply(simA_wide[,-1], 1, nth_doubling, n=2, init=initial_value),#
  Third  = apply(simA_wide[,-1], 1, nth_doubling, n=3, init=initial_value)#
) %>%#
  pivot_longer(everything(), names_to="Doubling", values_to="Year")#
#
# Median for reference#
median_times <- doubling_times_df %>%#
  group_by(Doubling) %>%#
  summarize(MedianYear = median(Year, na.rm=TRUE))#
#
print(median_times)#
#
# Plot#
ggplot(doubling_times_df, aes(x=Year, fill=Doubling)) +#
  geom_histogram(binwidth=1, alpha=0.5, position="identity", color="white") +#
  geom_vline(data=median_times, aes(xintercept=MedianYear, color=Doubling),#
             linetype="dashed", size=1) +#
  labs(title="Distributions of First, Second, and Third Doubling Times",#
       x="Year",#
       y="Frequency") +#
  scale_fill_manual(values=c("#1f77b4", "#d62728", "#2ca02c")) +#
  scale_color_manual(values=c("#1f77b4", "#d62728", "#2ca02c")) +#
  theme_minimal()
# Accumulation contributions effect#
simulate_contrib_effect <- function(sim_df, monthly_contrib, annual_raise_pct) {#
  n_years <- ncol(sim_df)#
  n_sim <- nrow(sim_df)#
  contrib_mat <- matrix(0, nrow = n_sim, ncol = n_years)#
  for (year in 1:n_years) {#
    contrib_mat[, year] <- ifelse(year == 1, monthly_contrib * 12, 0)#
    if (year > 1) {#
      contrib_mat[, year] <- contrib_mat[, year] + contrib_mat[, year - 1] * (1 + annual_raise_pct)#
    }#
  }#
  contrib_mat#
}#
#
# Example: portfolio A#
contrib_mat_A <- simulate_contrib_effect(simA, monthly_contrib, annual_raise_pct)#
returns_only_A <- simA - contrib_mat_A#
