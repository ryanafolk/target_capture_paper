# Parameters#
years <- 30#
monthly_contrib <- 2326#
annual_contrib <- monthly_contrib * 12#
contrib_growth <- 0.02   # annual increase in contributions#
nominal_return <- 0.09   # 9% nominal#
initial_value <- 193000#
#
# Initialize vectors#
FV_total <- numeric(years)#
FV_contrib_only <- numeric(years)#
contrib_fraction <- numeric(years)#
#
FV_total[1] <- initial_value * (1 + nominal_return) + annual_contrib#
FV_contrib_only[1] <- initial_value + annual_contrib#
contrib_fraction[1] <- FV_contrib_only[1] / FV_total[1]#
#
for (t in 2:years) {#
  annual_contrib_t <- annual_contrib * (1 + contrib_growth)^(t - 1)#
  # total FV with market returns#
  FV_total[t] <- FV_total[t - 1] * (1 + nominal_return) + annual_contrib_t#
  # FV if returns = 0 (just contributions)#
  FV_contrib_only[t] <- FV_contrib_only[t - 1] + annual_contrib_t#
  # fraction due to contributions#
  contrib_fraction[t] <- FV_contrib_only[t] / FV_total[t]#
}#
#
# Plot#
library(ggplot2)#
#
df <- data.frame(#
  Year = 1:years,#
  ContributionFraction = contrib_fraction#
)#
#
ggplot(df, aes(x = Year, y = ContributionFraction)) +#
  geom_line(color = "#2ca02c", linewidth = 1.2) +#
  scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +#
  labs(title = "Effect of Contributions vs. Market Compounding",#
       y = "Fraction of Total FV Due to Contributions",#
       x = "Year") +#
  theme_minimal(base_size = 13)
